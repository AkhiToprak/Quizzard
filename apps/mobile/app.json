{
  "expo": {
    "name": "Notemage",
    "slug": "notemage-mobile",
    "version": "0.1.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "notemage",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0d20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.notemage.mobile",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:notemage.app"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Notemage uses Face ID to keep your notebooks private after the app is unlocked the first time."
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0d20"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "app.notemage.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "notemage.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-pencil-module.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0e0d20",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ae89ff"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Notemage uses Face ID to re-unlock your notebooks after the app is backgrounded."
        }
      ],
      "expo-apple-authentication"
    ]
  }
}
